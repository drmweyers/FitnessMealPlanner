<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mealPlan.planName %> - <%= brandInfo.name %></title>

  <!-- Google Fonts: Outfit (headings) + Inter (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* ============================================================
       CSS VARIABLES — Brand DNA + White-Label Override Support
       ============================================================ */
    :root {
      --brand-primary: <%= brandInfo.colors.primary || '#9333EA' %>;
      --brand-accent: <%= brandInfo.colors.accent || '#F97316' %>;
      --brand-text: <%= brandInfo.colors.text || '#1a1a2e' %>;
      --brand-grey: <%= brandInfo.colors.grey || '#f4f4f8' %>;

      /* Extended palette */
      --dark-bg: #0A0A0F;
      --dark-surface: #12121A;
      --dark-card: #1A1A26;
      --dark-border: #2A2A3A;
      --white: #ffffff;
      --off-white: #F8F8FC;
      --light-grey: #E8E8F0;
      --mid-grey: #94949E;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
      --shadow-lg: 0 8px 30px rgba(0,0,0,0.12);

      /* Macro colors */
      --macro-protein: #9333EA;
      --macro-carbs: #F97316;
      --macro-fat: #3B82F6;

      /* Spacing scale */
      --sp-xs: 4px;
      --sp-sm: 8px;
      --sp-md: 16px;
      --sp-lg: 24px;
      --sp-xl: 32px;
      --sp-2xl: 48px;
      --sp-3xl: 64px;
    }

    /* ============================================================
       RESET & BASE
       ============================================================ */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10pt;
      line-height: 1.6;
      color: var(--brand-text);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.4em;
      break-after: avoid;
      page-break-after: avoid;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    h1 { font-size: 28pt; font-weight: 900; letter-spacing: -0.02em; }
    h2 { font-size: 20pt; font-weight: 800; letter-spacing: -0.01em; }
    h3 { font-size: 14pt; font-weight: 700; }
    h4 { font-size: 11pt; font-weight: 600; }

    p { margin-bottom: 0.6em; }

    /* ============================================================
       UTILITIES
       ============================================================ */
    .page-break {
      break-after: always;
      page-break-after: always;
    }

    .no-break {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .container {
      max-width: 100%;
      padding: 0 var(--sp-xl);
    }

    .section-label {
      font-family: 'Outfit', sans-serif;
      font-size: 8pt;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--brand-primary);
      margin-bottom: var(--sp-sm);
    }

    .section-title {
      color: var(--brand-text);
      margin-bottom: var(--sp-lg);
      position: relative;
      padding-bottom: var(--sp-md);
      break-after: avoid;
      page-break-after: avoid;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent));
      border-radius: 2px;
    }

    .accent-line {
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, var(--brand-primary), var(--brand-accent));
      border-radius: 2px;
    }

    .badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 100px;
      font-size: 8pt;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .badge-purple {
      background: rgba(147, 51, 234, 0.12);
      color: var(--macro-protein);
    }

    .badge-orange {
      background: rgba(249, 115, 22, 0.12);
      color: var(--macro-carbs);
    }

    .badge-blue {
      background: rgba(59, 130, 246, 0.12);
      color: var(--macro-fat);
    }

    .badge-dark {
      background: var(--dark-bg);
      color: var(--white);
    }

    /* ============================================================
       COVER PAGE — Dark Premium Hero
       ============================================================ */
    .cover-page {
      min-height: 100vh;
      background: var(--dark-bg);
      color: var(--white);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* Top gradient bar */
    .cover-gradient-bar {
      height: 5px;
      background: linear-gradient(90deg, var(--brand-primary) 0%, var(--brand-accent) 50%, var(--brand-primary) 100%);
      flex-shrink: 0;
    }

    /* Decorative background glow */
    .cover-bg-glow {
      position: absolute;
      top: -120px;
      right: -120px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(147, 51, 234, 0.15) 0%, transparent 70%);
      pointer-events: none;
    }

    .cover-bg-glow-2 {
      position: absolute;
      bottom: -80px;
      left: -80px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(249, 115, 22, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .cover-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--sp-3xl) var(--sp-2xl);
      position: relative;
      z-index: 1;
    }

    /* Logo / Brand mark */
    .cover-brand {
      display: flex;
      align-items: center;
      gap: var(--sp-md);
      margin-bottom: var(--sp-3xl);
    }

    .cover-logo-icon {
      width: 52px;
      height: 52px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24pt;
      color: var(--white);
      position: relative;
    }

    /* CSS fork/knife icon */
    .cover-logo-icon::before {
      content: '';
      position: absolute;
      width: 3px;
      height: 22px;
      background: var(--white);
      border-radius: 2px;
      left: 18px;
      top: 12px;
      transform: rotate(-8deg);
    }

    .cover-logo-icon::after {
      content: '';
      position: absolute;
      width: 3px;
      height: 22px;
      background: var(--white);
      border-radius: 2px;
      right: 18px;
      top: 12px;
      transform: rotate(8deg);
      box-shadow: -6px -2px 0 0 var(--white), 6px -2px 0 0 var(--white);
    }

    .cover-brand-name {
      font-family: 'Outfit', sans-serif;
      font-size: 22pt;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .cover-brand-name span {
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Plan title block */
    .cover-plan-label {
      font-family: 'Outfit', sans-serif;
      font-size: 9pt;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: var(--sp-md);
    }

    .cover-plan-title {
      font-family: 'Outfit', sans-serif;
      font-size: 36pt;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: var(--sp-sm);
      max-width: 80%;
    }

    .cover-plan-subtitle {
      font-size: 14pt;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: var(--sp-2xl);
    }

    /* Meta grid */
    .cover-meta-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-md);
      max-width: 600px;
    }

    .cover-meta-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: var(--sp-md) var(--sp-lg);
    }

    .cover-meta-label {
      font-size: 8pt;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.4);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 4px;
    }

    .cover-meta-value {
      font-family: 'Outfit', sans-serif;
      font-size: 12pt;
      font-weight: 600;
      color: var(--white);
    }

    /* Cover footer */
    .cover-footer {
      padding: var(--sp-lg) var(--sp-2xl);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      position: relative;
      z-index: 1;
    }

    .cover-footer-text {
      font-size: 9pt;
      color: rgba(255, 255, 255, 0.35);
    }

    .cover-footer-date {
      font-size: 9pt;
      color: rgba(255, 255, 255, 0.35);
    }

    /* ============================================================
       TABLE OF CONTENTS
       ============================================================ */
    .toc-page {
      padding: var(--sp-3xl) 0;
    }

    .toc-list {
      list-style: none;
      margin-top: var(--sp-xl);
    }

    .toc-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--light-grey);
      transition: background 0.1s;
    }

    .toc-item:last-child {
      border-bottom: none;
    }

    .toc-item-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 11pt;
      color: var(--brand-text);
    }

    .toc-item-page {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 11pt;
      color: var(--brand-primary);
      min-width: 30px;
      text-align: right;
    }

    .toc-item-dots {
      flex: 1;
      border-bottom: 2px dotted var(--light-grey);
      margin: 0 var(--sp-md);
      position: relative;
      top: 2px;
    }

    /* ============================================================
       OVERVIEW PAGE
       ============================================================ */
    .overview-page {
      padding: var(--sp-2xl) 0;
    }

    .overview-hero {
      background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1032 100%);
      border-radius: 16px;
      padding: var(--sp-xl) var(--sp-xl);
      color: var(--white);
      margin-bottom: var(--sp-xl);
      position: relative;
      overflow: hidden;
    }

    .overview-hero::before {
      content: '';
      position: absolute;
      top: -50px;
      right: -50px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(147, 51, 234, 0.2) 0%, transparent 70%);
    }

    .overview-hero-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--sp-md);
      position: relative;
      z-index: 1;
    }

    .overview-stat-card {
      text-align: center;
      padding: var(--sp-md);
    }

    .overview-stat-value {
      font-family: 'Outfit', sans-serif;
      font-size: 26pt;
      font-weight: 900;
      background: linear-gradient(135deg, var(--white), rgba(255,255,255,0.7));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 4px;
    }

    .overview-stat-label {
      font-size: 8pt;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .overview-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xl);
    }

    .overview-about {
      padding-right: var(--sp-lg);
    }

    .overview-about h3 {
      color: var(--brand-text);
      margin-bottom: var(--sp-md);
    }

    .overview-about p {
      color: var(--mid-grey);
      font-size: 10pt;
      line-height: 1.7;
    }

    .overview-features {
      list-style: none;
      margin-top: var(--sp-lg);
    }

    .overview-features li {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
      padding: 8px 0;
      font-size: 10pt;
      color: var(--brand-text);
    }

    .overview-features li::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--brand-primary);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .overview-stats-panel {
      background: var(--off-white);
      border-radius: 12px;
      padding: var(--sp-lg);
      border-left: 3px solid var(--brand-primary);
    }

    .overview-stats-panel h3 {
      color: var(--brand-text);
      margin-bottom: var(--sp-md);
      font-size: 12pt;
    }

    .stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid var(--light-grey);
    }

    .stat-row:last-child {
      border-bottom: none;
    }

    .stat-row-label {
      font-size: 10pt;
      color: var(--mid-grey);
      font-weight: 500;
    }

    .stat-row-value {
      font-family: 'Outfit', sans-serif;
      font-size: 12pt;
      font-weight: 700;
      color: var(--brand-primary);
    }

    /* Macro progress bars */
    .macro-bars {
      margin-top: var(--sp-lg);
    }

    .macro-bar-row {
      margin-bottom: var(--sp-md);
    }

    .macro-bar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .macro-bar-label {
      font-size: 9pt;
      font-weight: 600;
      color: var(--brand-text);
    }

    .macro-bar-value {
      font-family: 'Outfit', sans-serif;
      font-size: 9pt;
      font-weight: 700;
    }

    .macro-bar-track {
      width: 100%;
      height: 8px;
      background: var(--light-grey);
      border-radius: 4px;
      overflow: hidden;
    }

    .macro-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s ease;
    }

    .macro-bar-fill-protein { background: linear-gradient(90deg, #7C3AED, #9333EA); }
    .macro-bar-fill-carbs { background: linear-gradient(90deg, #EA580C, #F97316); }
    .macro-bar-fill-fat { background: linear-gradient(90deg, #2563EB, #3B82F6); }

    /* ============================================================
       WEEKLY SCHEDULE
       ============================================================ */
    .schedule-page {
      padding: var(--sp-2xl) 0;
    }

    .week-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 10px;
      margin-top: var(--sp-xl);
    }

    .day-column {
      break-inside: avoid;
    }

    .day-header {
      background: linear-gradient(135deg, var(--dark-bg), #1a1032);
      color: var(--white);
      padding: 10px 8px;
      text-align: center;
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 9pt;
      border-radius: 8px 8px 0 0;
      letter-spacing: 0.02em;
    }

    .day-meals {
      border: 1px solid var(--light-grey);
      border-top: none;
      border-radius: 0 0 8px 8px;
      background: var(--white);
    }

    .day-meal-item {
      padding: 8px 8px;
      border-bottom: 1px solid var(--light-grey);
      font-size: 8pt;
    }

    .day-meal-item:last-child {
      border-bottom: none;
    }

    .day-meal-type {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 7pt;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--brand-accent);
      margin-bottom: 2px;
    }

    .day-meal-name {
      font-size: 8pt;
      color: var(--brand-text);
      font-weight: 500;
      line-height: 1.3;
    }

    /* ============================================================
       DAILY MEAL PAGES
       ============================================================ */
    .daily-page {
      padding: var(--sp-2xl) 0;
    }

    .daily-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: var(--sp-xl);
      padding-bottom: var(--sp-md);
      border-bottom: 2px solid var(--light-grey);
      break-inside: avoid;
      page-break-inside: avoid;
      break-after: avoid;
      page-break-after: avoid;
    }

    .daily-header-left .section-label {
      margin-bottom: var(--sp-xs);
    }

    .daily-title {
      font-size: 22pt;
      color: var(--brand-text);
      margin-bottom: 0;
    }

    .daily-totals-bar {
      display: flex;
      gap: var(--sp-md);
      align-items: center;
    }

    .daily-total-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 100px;
      font-size: 9pt;
      font-weight: 600;
    }

    .daily-total-pill.cal {
      background: var(--dark-bg);
      color: var(--white);
    }

    .daily-total-pill.protein {
      background: rgba(147, 51, 234, 0.1);
      color: var(--macro-protein);
    }

    .daily-total-pill.carbs {
      background: rgba(249, 115, 22, 0.1);
      color: var(--macro-carbs);
    }

    .daily-total-pill.fat {
      background: rgba(59, 130, 246, 0.1);
      color: var(--macro-fat);
    }

    .daily-total-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .meal-cards-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-lg);
    }

    .meal-card {
      border: 1px solid var(--light-grey);
      border-radius: 12px;
      overflow: hidden;
      background: var(--white);
      box-shadow: var(--shadow-sm);
      break-inside: avoid;
      border-left: 3px solid var(--brand-primary);
    }

    .meal-card-top {
      padding: var(--sp-md) var(--sp-lg);
      background: var(--off-white);
      border-bottom: 1px solid var(--light-grey);
    }

    .meal-card-type-label {
      font-family: 'Outfit', sans-serif;
      font-size: 8pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--brand-accent);
      margin-bottom: 4px;
    }

    .meal-card-name {
      font-family: 'Outfit', sans-serif;
      font-size: 13pt;
      font-weight: 700;
      color: var(--brand-text);
      margin: 0;
      line-height: 1.3;
    }

    .meal-card-body {
      padding: var(--sp-md) var(--sp-lg);
    }

    .meal-card-desc {
      font-size: 9pt;
      color: var(--mid-grey);
      margin-bottom: var(--sp-sm);
      line-height: 1.5;
    }

    .meal-card-macros {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: var(--sp-sm);
    }

    .meal-card-macro {
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 8pt;
      font-weight: 600;
    }

    .meal-card-meta {
      display: flex;
      align-items: center;
      gap: var(--sp-md);
      font-size: 9pt;
      color: var(--mid-grey);
      padding-top: var(--sp-sm);
      border-top: 1px solid var(--light-grey);
    }

    .meal-card-meta-item {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    /* ============================================================
       RECIPE DETAIL PAGES
       ============================================================ */
    .recipe-page {
      padding: var(--sp-2xl) 0;
    }

    .recipe-header-bar {
      background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1032 100%);
      border-radius: 16px;
      padding: var(--sp-xl) var(--sp-xl);
      color: var(--white);
      margin-bottom: var(--sp-xl);
      position: relative;
      overflow: hidden;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .recipe-header-bar::before {
      content: '';
      position: absolute;
      top: -30px;
      right: -30px;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, rgba(147, 51, 234, 0.2) 0%, transparent 70%);
    }

    .recipe-header-type {
      font-family: 'Outfit', sans-serif;
      font-size: 8pt;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--brand-accent);
      margin-bottom: var(--sp-sm);
      position: relative;
      z-index: 1;
    }

    .recipe-header-title {
      font-family: 'Outfit', sans-serif;
      font-size: 22pt;
      font-weight: 800;
      margin-bottom: var(--sp-sm);
      position: relative;
      z-index: 1;
    }

    .recipe-header-desc {
      font-size: 10pt;
      color: rgba(255, 255, 255, 0.6);
      font-style: italic;
      position: relative;
      z-index: 1;
      margin-bottom: var(--sp-lg);
    }

    .recipe-stats-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: var(--sp-md);
      position: relative;
      z-index: 1;
    }

    .recipe-stat {
      text-align: center;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      padding: var(--sp-sm) var(--sp-sm);
    }

    .recipe-stat-value {
      font-family: 'Outfit', sans-serif;
      font-size: 16pt;
      font-weight: 800;
      color: var(--white);
      line-height: 1;
      margin-bottom: 2px;
    }

    .recipe-stat-label {
      font-size: 7pt;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.45);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .recipe-stat-value.protein-color { color: #C084FC; }
    .recipe-stat-value.carbs-color { color: #FB923C; }
    .recipe-stat-value.fat-color { color: #60A5FA; }

    /* Recipe content two-column */
    .recipe-content-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xl);
    }

    .recipe-section-title {
      font-family: 'Outfit', sans-serif;
      font-size: 12pt;
      font-weight: 700;
      color: var(--brand-text);
      margin-bottom: var(--sp-md);
      padding-bottom: var(--sp-sm);
      border-bottom: 2px solid var(--light-grey);
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
    }

    .recipe-section-title .icon-circle {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10pt;
      flex-shrink: 0;
    }

    .icon-circle-purple {
      background: rgba(147, 51, 234, 0.1);
      color: var(--macro-protein);
    }

    .icon-circle-orange {
      background: rgba(249, 115, 22, 0.1);
      color: var(--macro-carbs);
    }

    .ingredients-list {
      list-style: none;
    }

    .ingredient-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid var(--light-grey);
      font-size: 10pt;
    }

    .ingredient-row:last-child {
      border-bottom: none;
    }

    .ingredient-name {
      color: var(--brand-text);
      flex: 1;
    }

    .ingredient-amount {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      color: var(--brand-primary);
      white-space: nowrap;
      margin-left: var(--sp-md);
    }

    .instructions-list {
      list-style: none;
      counter-reset: step-counter;
    }

    .instruction-step {
      counter-increment: step-counter;
      margin-bottom: var(--sp-md);
      padding-left: 36px;
      position: relative;
      font-size: 10pt;
      line-height: 1.6;
      color: var(--brand-text);
    }

    .instruction-step::before {
      content: counter(step-counter);
      position: absolute;
      left: 0;
      top: 1px;
      width: 24px;
      height: 24px;
      background: linear-gradient(135deg, var(--brand-primary), #7C3AED);
      color: var(--white);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Outfit', sans-serif;
      font-size: 9pt;
      font-weight: 700;
    }

    /* ============================================================
       SHOPPING LIST
       ============================================================ */
    .shopping-page {
      padding: var(--sp-2xl) 0;
    }

    .shopping-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-lg);
      margin-top: var(--sp-xl);
    }

    .shopping-category {
      break-inside: avoid;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--light-grey);
      box-shadow: var(--shadow-sm);
    }

    .shopping-category-header {
      padding: 10px var(--sp-md);
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 10pt;
      color: var(--white);
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
    }

    .shopping-category-header.produce {
      background: linear-gradient(135deg, #16A34A, #22C55E);
    }

    .shopping-category-header.proteins {
      background: linear-gradient(135deg, #DC2626, #EF4444);
    }

    .shopping-category-header.dairy {
      background: linear-gradient(135deg, #2563EB, #3B82F6);
    }

    .shopping-category-header.grains {
      background: linear-gradient(135deg, #D97706, #F59E0B);
    }

    .shopping-category-header.pantry {
      background: linear-gradient(135deg, var(--brand-primary), #7C3AED);
    }

    .shopping-category-header.other {
      background: linear-gradient(135deg, #475569, #64748B);
    }

    .shopping-items-list {
      background: var(--white);
    }

    .shopping-item {
      display: flex;
      align-items: center;
      padding: 8px var(--sp-md);
      border-bottom: 1px solid var(--light-grey);
      font-size: 9pt;
    }

    .shopping-item:last-child {
      border-bottom: none;
    }

    .shopping-item:nth-child(even) {
      background: var(--off-white);
    }

    .shopping-checkbox {
      width: 14px;
      height: 14px;
      border: 2px solid var(--light-grey);
      border-radius: 3px;
      margin-right: var(--sp-sm);
      flex-shrink: 0;
    }

    .shopping-item-name {
      flex: 1;
      color: var(--brand-text);
      font-weight: 500;
    }

    .shopping-item-amount {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      color: var(--brand-primary);
      white-space: nowrap;
      margin-left: var(--sp-sm);
    }

    /* ============================================================
       NUTRITION SUMMARY
       ============================================================ */
    .nutrition-page {
      padding: var(--sp-2xl) 0;
    }

    .nutrition-hero {
      background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1032 100%);
      border-radius: 16px;
      padding: var(--sp-xl);
      color: var(--white);
      margin-bottom: var(--sp-xl);
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: var(--sp-xl);
      align-items: center;
      position: relative;
      overflow: hidden;
    }

    .nutrition-hero::before {
      content: '';
      position: absolute;
      top: -60px;
      right: -60px;
      width: 250px;
      height: 250px;
      background: radial-gradient(circle, rgba(147, 51, 234, 0.15) 0%, transparent 70%);
    }

    /* CSS-only donut chart */
    .macro-donut {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      position: relative;
      z-index: 1;
      margin: 0 auto;
    }

    .macro-donut-inner {
      position: absolute;
      top: 35px;
      left: 35px;
      right: 35px;
      bottom: 35px;
      background: var(--dark-bg);
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }

    .macro-donut-cals {
      font-family: 'Outfit', sans-serif;
      font-size: 20pt;
      font-weight: 900;
      line-height: 1;
    }

    .macro-donut-cals-label {
      font-size: 7pt;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.5);
      margin-top: 2px;
    }

    .macro-legend-grid {
      display: grid;
      grid-template-rows: repeat(3, 1fr);
      gap: var(--sp-md);
      position: relative;
      z-index: 1;
    }

    .macro-legend-item {
      display: flex;
      align-items: center;
      gap: var(--sp-md);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 10px;
      padding: var(--sp-md) var(--sp-lg);
    }

    .macro-legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 3px;
      flex-shrink: 0;
    }

    .macro-legend-dot.protein { background: var(--macro-protein); }
    .macro-legend-dot.carbs { background: var(--macro-carbs); }
    .macro-legend-dot.fat { background: var(--macro-fat); }

    .macro-legend-info {
      flex: 1;
    }

    .macro-legend-name {
      font-family: 'Outfit', sans-serif;
      font-size: 10pt;
      font-weight: 600;
    }

    .macro-legend-grams {
      font-size: 9pt;
      color: rgba(255,255,255,0.5);
    }

    .macro-legend-pct {
      font-family: 'Outfit', sans-serif;
      font-size: 18pt;
      font-weight: 800;
    }

    .macro-legend-pct.protein { color: #C084FC; }
    .macro-legend-pct.carbs { color: #FB923C; }
    .macro-legend-pct.fat { color: #60A5FA; }

    /* Daily averages grid */
    .nutrition-averages {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--sp-md);
    }

    .nutrition-avg-card {
      text-align: center;
      padding: var(--sp-lg);
      border-radius: 12px;
      background: var(--off-white);
      border-left: 3px solid var(--brand-primary);
    }

    .nutrition-avg-card:nth-child(2) { border-left-color: var(--macro-protein); }
    .nutrition-avg-card:nth-child(3) { border-left-color: var(--macro-carbs); }
    .nutrition-avg-card:nth-child(4) { border-left-color: var(--macro-fat); }

    .nutrition-avg-value {
      font-family: 'Outfit', sans-serif;
      font-size: 22pt;
      font-weight: 900;
      color: var(--brand-text);
      line-height: 1;
      margin-bottom: 4px;
    }

    .nutrition-avg-label {
      font-size: 9pt;
      color: var(--mid-grey);
      font-weight: 500;
    }

    .nutrition-avg-unit {
      font-size: 8pt;
      color: var(--mid-grey);
    }

    /* ============================================================
       MEAL PREP GUIDE
       ============================================================ */
    .prep-page {
      padding: var(--sp-2xl) 0;
    }

    .prep-tip-card {
      background: var(--off-white);
      border-left: 3px solid var(--brand-accent);
      border-radius: 0 12px 12px 0;
      padding: var(--sp-md) var(--sp-lg);
      margin-bottom: var(--sp-md);
      break-inside: avoid;
    }

    .prep-tip-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 11pt;
      color: var(--brand-text);
      margin-bottom: 4px;
    }

    .prep-tip-text {
      font-size: 10pt;
      color: var(--mid-grey);
      line-height: 1.6;
    }

    .prep-tip-time {
      display: inline-block;
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 9pt;
      color: var(--brand-accent);
      margin-top: 4px;
    }

    /* ============================================================
       FOOTER — Every Page
       ============================================================ */
    .page-footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 10px var(--sp-xl);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 8pt;
      color: var(--mid-grey);
      border-top: 1px solid var(--light-grey);
      background: var(--white);
    }

    .footer-brand {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      color: var(--brand-primary);
    }

    .footer-powered {
      font-size: 7pt;
      color: var(--mid-grey);
    }

    .footer-page {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
    }

    /* ============================================================
       PRINT STYLES
       ============================================================ */
    @media print {
      body {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;
      }

      .page-break {
        page-break-after: always !important;
        break-after: page !important;
      }

      .no-break {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
      }

      .cover-page {
        -webkit-print-color-adjust: exact !important;
      }

      .page-footer {
        position: fixed;
        bottom: 0;
      }

      @page {
        margin: 15mm 12mm 20mm 12mm;
        size: <%= options.pageSize === 'Letter' ? 'letter' : 'A4' %> <%= options.orientation || 'portrait' %>;
      }

      @page :first {
        margin: 0;
      }
    }
  </style>
</head>
<body>

  <!-- ============================================================
       COVER PAGE
       ============================================================ -->
  <div class="cover-page">
    <div class="cover-gradient-bar"></div>
    <div class="cover-bg-glow"></div>
    <div class="cover-bg-glow-2"></div>

    <div class="cover-content">
      <!-- Brand -->
      <div class="cover-brand">
        <div class="cover-logo-icon"></div>
        <div class="cover-brand-name"><span><%= brandInfo.name %></span></div>
      </div>

      <!-- Plan Title -->
      <div class="cover-plan-label">Personalized Nutrition Plan</div>
      <div class="cover-plan-title"><%= mealPlan.planName %></div>
      <div class="cover-plan-subtitle">Designed for <%= customerName %></div>

      <!-- Meta Cards -->
      <div class="cover-meta-grid">
        <div class="cover-meta-card">
          <div class="cover-meta-label">Client</div>
          <div class="cover-meta-value"><%= customerName %></div>
        </div>
        <div class="cover-meta-card">
          <div class="cover-meta-label">Goal</div>
          <div class="cover-meta-value"><%= helpers.formatFitnessGoal(mealPlan.fitnessGoal) %></div>
        </div>
        <div class="cover-meta-card">
          <div class="cover-meta-label">Daily Target</div>
          <div class="cover-meta-value"><%= mealPlan.dailyCalorieTarget %> kcal</div>
        </div>
        <div class="cover-meta-card">
          <div class="cover-meta-label">Duration</div>
          <div class="cover-meta-value"><%= mealPlan.days %> Days</div>
        </div>
        <div class="cover-meta-card">
          <div class="cover-meta-label">Prepared By</div>
          <div class="cover-meta-value"><%= generatedBy %></div>
        </div>
        <div class="cover-meta-card">
          <div class="cover-meta-label">Date</div>
          <div class="cover-meta-value"><%= generatedDate %></div>
        </div>
      </div>
    </div>

    <div class="cover-footer">
      <div class="cover-footer-text"><%= brandInfo.website %></div>
      <div class="cover-footer-date">Generated <%= generatedDate %></div>
    </div>
  </div>

  <div class="page-break"></div>

  <!-- ============================================================
       TABLE OF CONTENTS
       ============================================================ -->
  <div class="toc-page">
    <div class="container">
      <div class="section-label">Navigation</div>
      <h2 class="section-title">Table of Contents</h2>

      <ul class="toc-list">
        <% tableOfContents.forEach(item => { %>
          <li class="toc-item">
            <span class="toc-item-title"><%= item.title %></span>
            <span class="toc-item-dots"></span>
            <span class="toc-item-page"><%= item.page %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>

  <div class="page-break"></div>

  <!-- ============================================================
       PLAN OVERVIEW
       ============================================================ -->
  <div class="overview-page">
    <div class="container">
      <div class="section-label">Your Plan</div>
      <h2 class="section-title">Plan Overview</h2>

      <!-- Hero Stats Bar -->
      <div class="overview-hero">
        <div class="overview-hero-grid">
          <div class="overview-stat-card">
            <div class="overview-stat-value"><%= mealPlan.days %></div>
            <div class="overview-stat-label">Days</div>
          </div>
          <div class="overview-stat-card">
            <div class="overview-stat-value"><%= mealPlan.meals.length %></div>
            <div class="overview-stat-label">Recipes</div>
          </div>
          <div class="overview-stat-card">
            <div class="overview-stat-value"><%= helpers.formatNumber(nutritionTotals.avgCaloriesPerDay) %></div>
            <div class="overview-stat-label">Avg Calories</div>
          </div>
          <div class="overview-stat-card">
            <div class="overview-stat-value"><%= mealPlan.mealsPerDay %></div>
            <div class="overview-stat-label">Meals/Day</div>
          </div>
        </div>
      </div>

      <!-- Two Column: About + Stats -->
      <div class="overview-grid">
        <div class="overview-about">
          <h3>About This Plan</h3>
          <p><%= mealPlan.description || `This ${mealPlan.days}-day nutrition plan is specifically designed for ${helpers.formatFitnessGoal(mealPlan.fitnessGoal)} with a daily calorie target of ${mealPlan.dailyCalorieTarget} calories.` %></p>

          <ul class="overview-features">
            <li><%= mealPlan.meals.length %> chef-designed recipes</li>
            <li><%= mealPlan.mealsPerDay %> balanced meals per day</li>
            <li>Complete nutritional breakdown per meal</li>
            <li>Step-by-step cooking instructions</li>
            <li>Consolidated grocery shopping list</li>
          </ul>
        </div>

        <div class="overview-stats-panel">
          <h3>Daily Averages</h3>

          <div class="stat-row">
            <span class="stat-row-label">Calories</span>
            <span class="stat-row-value"><%= helpers.formatNumber(nutritionTotals.avgCaloriesPerDay) %> kcal</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">Protein</span>
            <span class="stat-row-value"><%= helpers.formatNumber(nutritionTotals.avgProteinPerDay) %>g</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">Carbs</span>
            <span class="stat-row-value"><%= helpers.formatNumber(nutritionTotals.avgCarbsPerDay) %>g</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">Fat</span>
            <span class="stat-row-value"><%= helpers.formatNumber(nutritionTotals.avgFatPerDay) %>g</span>
          </div>

          <!-- Macro distribution bars -->
          <%
            const macroData = generateMacroChartData(nutritionTotals);
          %>
          <div class="macro-bars">
            <div class="macro-bar-row">
              <div class="macro-bar-header">
                <span class="macro-bar-label">Protein</span>
                <span class="macro-bar-value" style="color: var(--macro-protein);"><%= macroData.protein %>%</span>
              </div>
              <div class="macro-bar-track">
                <div class="macro-bar-fill macro-bar-fill-protein" style="width: <%= macroData.protein %>%;"></div>
              </div>
            </div>
            <div class="macro-bar-row">
              <div class="macro-bar-header">
                <span class="macro-bar-label">Carbs</span>
                <span class="macro-bar-value" style="color: var(--macro-carbs);"><%= macroData.carbs %>%</span>
              </div>
              <div class="macro-bar-track">
                <div class="macro-bar-fill macro-bar-fill-carbs" style="width: <%= macroData.carbs %>%;"></div>
              </div>
            </div>
            <div class="macro-bar-row">
              <div class="macro-bar-header">
                <span class="macro-bar-label">Fat</span>
                <span class="macro-bar-value" style="color: var(--macro-fat);"><%= macroData.fat %>%</span>
              </div>
              <div class="macro-bar-track">
                <div class="macro-bar-fill macro-bar-fill-fat" style="width: <%= macroData.fat %>%;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="page-break"></div>

  <!-- ============================================================
       WEEKLY MEAL SCHEDULE
       ============================================================ -->
  <div class="schedule-page">
    <div class="container">
      <div class="section-label">Schedule</div>
      <h2 class="section-title">Weekly Meal Schedule</h2>

      <% if (mealPlan.days <= 7) { %>
        <div class="week-grid">
          <% for (let day = 1; day <= mealPlan.days; day++) { %>
            <div class="day-column no-break">
              <div class="day-header">Day <%= day %></div>
              <div class="day-meals">
                <% if (mealsByDay[day]) { %>
                  <% mealsByDay[day].forEach(meal => { %>
                    <div class="day-meal-item">
                      <div class="day-meal-type"><%= helpers.formatMealType(meal.mealType) %></div>
                      <div class="day-meal-name"><%= meal.recipe.name %></div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <div class="day-meal-item">
                    <div class="day-meal-name" style="color: var(--mid-grey); font-style: italic;">Rest day</div>
                  </div>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <!-- Multi-week plans: show week at a time -->
        <% const totalWeeks = Math.ceil(mealPlan.days / 7); %>
        <% for (let week = 0; week < totalWeeks; week++) { %>
          <% if (week > 0) { %><div style="margin-top: var(--sp-xl);"></div><% } %>
          <h3 style="color: var(--brand-primary); margin-bottom: var(--sp-md);">Week <%= week + 1 %></h3>
          <div class="week-grid" style="grid-template-columns: repeat(<%= Math.min(7, mealPlan.days - week * 7) %>, 1fr);">
            <% for (let d = week * 7 + 1; d <= Math.min((week + 1) * 7, mealPlan.days); d++) { %>
              <div class="day-column no-break">
                <div class="day-header">Day <%= d %></div>
                <div class="day-meals">
                  <% if (mealsByDay[d]) { %>
                    <% mealsByDay[d].forEach(meal => { %>
                      <div class="day-meal-item">
                        <div class="day-meal-type"><%= helpers.formatMealType(meal.mealType) %></div>
                        <div class="day-meal-name"><%= meal.recipe.name %></div>
                      </div>
                    <% }); %>
                  <% } else { %>
                    <div class="day-meal-item">
                      <div class="day-meal-name" style="color: var(--mid-grey); font-style: italic;">Rest day</div>
                    </div>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </div>
  </div>

  <!-- ============================================================
       DAILY MEAL PAGES
       ============================================================ -->
  <% Object.keys(mealsByDay).forEach(day => { %>
    <div class="page-break"></div>
    <div class="daily-page">
      <div class="container">
        <div class="daily-header">
          <div class="daily-header-left">
            <div class="section-label">Daily Plan</div>
            <h2 class="daily-title">Day <%= day %></h2>
          </div>
          <div class="daily-totals-bar">
            <%
              const dayCalories = mealsByDay[day].reduce((sum, meal) => sum + meal.recipe.caloriesKcal, 0);
              const dayProtein = mealsByDay[day].reduce((sum, meal) => sum + parseFloat(meal.recipe.proteinGrams), 0);
              const dayCarbs = mealsByDay[day].reduce((sum, meal) => sum + parseFloat(meal.recipe.carbsGrams), 0);
              const dayFat = mealsByDay[day].reduce((sum, meal) => sum + parseFloat(meal.recipe.fatGrams), 0);
            %>
            <div class="daily-total-pill cal"><%= dayCalories %> kcal</div>
            <div class="daily-total-pill protein">
              <div class="daily-total-dot" style="background: var(--macro-protein);"></div>
              <%= helpers.formatNumber(dayProtein) %>g P
            </div>
            <div class="daily-total-pill carbs">
              <div class="daily-total-dot" style="background: var(--macro-carbs);"></div>
              <%= helpers.formatNumber(dayCarbs) %>g C
            </div>
            <div class="daily-total-pill fat">
              <div class="daily-total-dot" style="background: var(--macro-fat);"></div>
              <%= helpers.formatNumber(dayFat) %>g F
            </div>
          </div>
        </div>

        <div class="meal-cards-grid">
          <% mealsByDay[day].forEach(meal => { %>
            <div class="meal-card no-break">
              <div class="meal-card-top">
                <div class="meal-card-type-label"><%= helpers.formatMealType(meal.mealType) %></div>
                <h4 class="meal-card-name"><%= meal.recipe.name %></h4>
              </div>
              <div class="meal-card-body">
                <% if (meal.recipe.description) { %>
                  <p class="meal-card-desc"><%= meal.recipe.description %></p>
                <% } %>

                <div class="meal-card-macros">
                  <span class="meal-card-macro badge-dark"><%= meal.recipe.caloriesKcal %> kcal</span>
                  <span class="meal-card-macro badge-purple"><%= meal.recipe.proteinGrams %>g protein</span>
                  <span class="meal-card-macro badge-orange"><%= meal.recipe.carbsGrams %>g carbs</span>
                  <span class="meal-card-macro badge-blue"><%= meal.recipe.fatGrams %>g fat</span>
                </div>

                <div class="meal-card-meta">
                  <div class="meal-card-meta-item">
                    <span style="color: var(--brand-accent); font-weight: 600;"><%- '&#9201;' %></span>
                    <span><%= meal.recipe.prepTimeMinutes %> min</span>
                  </div>
                  <div class="meal-card-meta-item">
                    <span style="color: var(--brand-primary); font-weight: 600;"><%- '&#127860;' %></span>
                    <span><%= meal.recipe.servings %> serving<%= meal.recipe.servings > 1 ? 's' : '' %></span>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  <% }); %>

  <!-- ============================================================
       RECIPE DETAIL PAGES
       ============================================================ -->
  <% mealPlan.meals.forEach(meal => { %>
    <div class="page-break"></div>
    <div class="recipe-page">
      <div class="container">

        <!-- Dark header bar -->
        <div class="recipe-header-bar">
          <div class="recipe-header-type">
            <%= helpers.formatMealType(meal.mealType) %> &mdash; Day <%= meal.day %>
          </div>
          <h2 class="recipe-header-title"><%= meal.recipe.name %></h2>
          <% if (meal.recipe.description) { %>
            <p class="recipe-header-desc"><%= meal.recipe.description %></p>
          <% } %>

          <div class="recipe-stats-row">
            <div class="recipe-stat">
              <div class="recipe-stat-value"><%= meal.recipe.prepTimeMinutes %></div>
              <div class="recipe-stat-label">Minutes</div>
            </div>
            <div class="recipe-stat">
              <div class="recipe-stat-value"><%= meal.recipe.servings %></div>
              <div class="recipe-stat-label">Servings</div>
            </div>
            <div class="recipe-stat">
              <div class="recipe-stat-value"><%= meal.recipe.caloriesKcal %></div>
              <div class="recipe-stat-label">Calories</div>
            </div>
            <div class="recipe-stat">
              <div class="recipe-stat-value protein-color"><%= meal.recipe.proteinGrams %>g</div>
              <div class="recipe-stat-label">Protein</div>
            </div>
            <div class="recipe-stat">
              <div class="recipe-stat-value carbs-color"><%= meal.recipe.carbsGrams %>g</div>
              <div class="recipe-stat-label">Carbs</div>
            </div>
          </div>
        </div>

        <!-- Two-column: Ingredients + Instructions -->
        <div class="recipe-content-grid">
          <div>
            <div class="recipe-section-title">
              <span class="icon-circle icon-circle-purple">&#9733;</span>
              Ingredients
            </div>
            <ul class="ingredients-list">
              <% meal.recipe.ingredientsJson.forEach(ingredient => { %>
                <li class="ingredient-row">
                  <span class="ingredient-name"><%= ingredient.name %></span>
                  <span class="ingredient-amount"><%= ingredient.amount %> <%= ingredient.unit %></span>
                </li>
              <% }); %>
            </ul>
          </div>

          <div>
            <div class="recipe-section-title">
              <span class="icon-circle icon-circle-orange">&#9998;</span>
              Instructions
            </div>
            <ol class="instructions-list">
              <%
                const instructions = meal.recipe.instructionsText.split(/\d+\.|\n/).filter(step => step.trim());
                instructions.forEach(instruction => {
              %>
                <li class="instruction-step"><%= instruction.trim() %></li>
              <% }); %>
            </ol>
          </div>
        </div>

        <% if (meal.recipe.dietaryTags && meal.recipe.dietaryTags.length > 0) { %>
          <div style="margin-top: var(--sp-lg); display: flex; gap: 6px; flex-wrap: wrap;">
            <% meal.recipe.dietaryTags.forEach(tag => { %>
              <span class="badge badge-purple"><%= tag %></span>
            <% }); %>
          </div>
        <% } %>

      </div>
    </div>
  <% }); %>

  <!-- ============================================================
       SHOPPING LIST
       ============================================================ -->
  <% if (options.includeShoppingList && shoppingList) { %>
    <div class="page-break"></div>
    <div class="shopping-page">
      <div class="container">
        <div class="section-label">Grocery</div>
        <h2 class="section-title">Shopping List</h2>
        <p style="color: var(--mid-grey); margin-bottom: var(--sp-xl);">
          Everything you need for your <%= mealPlan.days %>-day meal plan. Check items off as you shop.
        </p>

        <%
          // Categorize shopping list items
          const produceKeywords = ['tomato', 'lettuce', 'onion', 'garlic', 'pepper', 'carrot', 'spinach', 'broccoli', 'cucumber', 'avocado', 'lemon', 'lime', 'apple', 'banana', 'berry', 'fruit', 'vegetable', 'zucchini', 'kale', 'celery', 'mushroom', 'potato', 'sweet potato', 'ginger', 'basil', 'cilantro', 'parsley', 'mint', 'thyme', 'rosemary', 'oregano', 'dill', 'cabbage', 'corn', 'peas', 'green beans', 'asparagus', 'cauliflower', 'beet', 'radish', 'squash', 'eggplant'];
          const proteinKeywords = ['chicken', 'beef', 'pork', 'fish', 'salmon', 'tuna', 'egg', 'tofu', 'protein', 'meat', 'turkey', 'shrimp', 'lamb', 'sausage', 'bacon', 'ham', 'steak', 'ground', 'cod', 'tilapia'];
          const dairyKeywords = ['milk', 'cheese', 'yogurt', 'cream', 'butter', 'sour cream', 'cottage', 'ricotta', 'mozzarella', 'cheddar', 'parmesan', 'whey'];
          const grainKeywords = ['rice', 'bread', 'pasta', 'oat', 'flour', 'tortilla', 'quinoa', 'cereal', 'granola', 'noodle', 'couscous', 'bagel', 'wrap'];

          const categorize = (item) => {
            const name = item.name.toLowerCase();
            if (produceKeywords.some(k => name.includes(k))) return 'produce';
            if (proteinKeywords.some(k => name.includes(k))) return 'proteins';
            if (dairyKeywords.some(k => name.includes(k))) return 'dairy';
            if (grainKeywords.some(k => name.includes(k))) return 'grains';
            return 'pantry';
          };

          const categories = {};
          shoppingList.forEach(item => {
            const cat = categorize(item);
            if (!categories[cat]) categories[cat] = [];
            categories[cat].push(item);
          });

          const categoryMeta = {
            produce: { label: 'Fresh Produce', cssClass: 'produce' },
            proteins: { label: 'Proteins & Meats', cssClass: 'proteins' },
            dairy: { label: 'Dairy & Eggs', cssClass: 'dairy' },
            grains: { label: 'Grains & Bread', cssClass: 'grains' },
            pantry: { label: 'Pantry Staples', cssClass: 'pantry' }
          };

          const orderedCats = ['produce', 'proteins', 'dairy', 'grains', 'pantry'].filter(c => categories[c] && categories[c].length > 0);
        %>

        <div class="shopping-grid">
          <% orderedCats.forEach(cat => { %>
            <div class="shopping-category no-break">
              <div class="shopping-category-header <%= categoryMeta[cat].cssClass %>">
                <%= categoryMeta[cat].label %>
                <span style="opacity: 0.7; font-weight: 400; margin-left: auto;">(<%= categories[cat].length %>)</span>
              </div>
              <div class="shopping-items-list">
                <% categories[cat].forEach(item => { %>
                  <div class="shopping-item">
                    <div class="shopping-checkbox"></div>
                    <span class="shopping-item-name"><%= item.name %></span>
                    <span class="shopping-item-amount"><%= item.formattedAmount %> <%= item.unit %></span>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- ============================================================
       NUTRITION SUMMARY
       ============================================================ -->
  <% if (options.includeMacroSummary) { %>
    <div class="page-break"></div>
    <div class="nutrition-page">
      <div class="container">
        <div class="section-label">Analytics</div>
        <h2 class="section-title">Nutritional Summary</h2>

        <%
          const macros = generateMacroChartData(nutritionTotals);
          // Calculate conic-gradient angles
          const proteinEnd = macros.protein * 3.6;
          const carbsEnd = proteinEnd + macros.carbs * 3.6;
        %>

        <!-- Donut chart + legend -->
        <div class="nutrition-hero">
          <div class="macro-donut" style="background: conic-gradient(
            var(--macro-protein) 0deg <%= proteinEnd %>deg,
            var(--macro-carbs) <%= proteinEnd %>deg <%= carbsEnd %>deg,
            var(--macro-fat) <%= carbsEnd %>deg 360deg
          );">
            <div class="macro-donut-inner">
              <div class="macro-donut-cals"><%= helpers.formatNumber(nutritionTotals.avgCaloriesPerDay) %></div>
              <div class="macro-donut-cals-label">kcal / day</div>
            </div>
          </div>

          <div class="macro-legend-grid">
            <div class="macro-legend-item">
              <div class="macro-legend-dot protein"></div>
              <div class="macro-legend-info">
                <div class="macro-legend-name">Protein</div>
                <div class="macro-legend-grams"><%= helpers.formatNumber(nutritionTotals.avgProteinPerDay) %>g / day</div>
              </div>
              <div class="macro-legend-pct protein"><%= macros.protein %>%</div>
            </div>
            <div class="macro-legend-item">
              <div class="macro-legend-dot carbs"></div>
              <div class="macro-legend-info">
                <div class="macro-legend-name">Carbohydrates</div>
                <div class="macro-legend-grams"><%= helpers.formatNumber(nutritionTotals.avgCarbsPerDay) %>g / day</div>
              </div>
              <div class="macro-legend-pct carbs"><%= macros.carbs %>%</div>
            </div>
            <div class="macro-legend-item">
              <div class="macro-legend-dot fat"></div>
              <div class="macro-legend-info">
                <div class="macro-legend-name">Healthy Fats</div>
                <div class="macro-legend-grams"><%= helpers.formatNumber(nutritionTotals.avgFatPerDay) %>g / day</div>
              </div>
              <div class="macro-legend-pct fat"><%= macros.fat %>%</div>
            </div>
          </div>
        </div>

        <!-- Daily Averages Cards -->
        <h3 style="margin-bottom: var(--sp-md);">Daily Averages</h3>
        <div class="nutrition-averages">
          <div class="nutrition-avg-card">
            <div class="nutrition-avg-value"><%= helpers.formatNumber(nutritionTotals.avgCaloriesPerDay) %></div>
            <div class="nutrition-avg-label">Calories</div>
            <div class="nutrition-avg-unit">kcal / day</div>
          </div>
          <div class="nutrition-avg-card">
            <div class="nutrition-avg-value"><%= helpers.formatNumber(nutritionTotals.avgProteinPerDay) %></div>
            <div class="nutrition-avg-label">Protein</div>
            <div class="nutrition-avg-unit">grams / day</div>
          </div>
          <div class="nutrition-avg-card">
            <div class="nutrition-avg-value"><%= helpers.formatNumber(nutritionTotals.avgCarbsPerDay) %></div>
            <div class="nutrition-avg-label">Carbs</div>
            <div class="nutrition-avg-unit">grams / day</div>
          </div>
          <div class="nutrition-avg-card">
            <div class="nutrition-avg-value"><%= helpers.formatNumber(nutritionTotals.avgFatPerDay) %></div>
            <div class="nutrition-avg-label">Fat</div>
            <div class="nutrition-avg-unit">grams / day</div>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- ============================================================
       MEAL PREP GUIDE (if plan has prep tips)
       ============================================================ -->
  <%
    // Generate prep tips from recipes with longer prep times
    const prepRecipes = mealPlan.meals
      .filter(m => m.recipe.prepTimeMinutes >= 15)
      .sort((a, b) => b.recipe.prepTimeMinutes - a.recipe.prepTimeMinutes)
      .slice(0, 8);
  %>
  <% if (prepRecipes.length > 0) { %>
    <div class="page-break"></div>
    <div class="prep-page">
      <div class="container">
        <div class="section-label">Efficiency</div>
        <h2 class="section-title">Meal Prep Guide</h2>
        <p style="color: var(--mid-grey); margin-bottom: var(--sp-xl);">
          Save time by batch-prepping these recipes. Listed by prep time, longest first.
        </p>

        <% prepRecipes.forEach((meal, idx) => { %>
          <div class="prep-tip-card no-break">
            <div class="prep-tip-title"><%= idx + 1 %>. <%= meal.recipe.name %></div>
            <div class="prep-tip-text">
              Scheduled for Day <%= meal.day %> (<%= helpers.formatMealType(meal.mealType) %>).
              Makes <%= meal.recipe.servings %> serving<%= meal.recipe.servings > 1 ? 's' : '' %>.
              <% if (meal.recipe.dietaryTags && meal.recipe.dietaryTags.length > 0) { %>
                Tags: <%= meal.recipe.dietaryTags.join(', ') %>.
              <% } %>
            </div>
            <div class="prep-tip-time">Prep time: <%= meal.recipe.prepTimeMinutes %> minutes</div>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <!-- ============================================================
       BRANDED FOOTER (Fixed on all pages)
       ============================================================ -->
  <div class="page-footer">
    <div>
      <span class="footer-brand"><%= brandInfo.name %></span>
      <% if (generatedBy) { %>
        <span style="margin-left: var(--sp-md);">Trainer: <%= generatedBy %></span>
      <% } %>
    </div>
    <div class="footer-powered">
      Powered by <%= brandInfo.name %> &bull; <%= brandInfo.website %>
    </div>
  </div>

</body>
</html>
